# ArangoGraph Connection (never commit .env — use .env.local for local dev)
# These are set per-request from encrypted session state — no server-side storage.

# Vercel AI SDK — set your provider key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Session encryption secret (min 32 chars, generate with: openssl rand -hex 32)
SESSION_SECRET=replace_with_32_char_random_hex_string

# Optional: default ArangoGraph endpoint for local development only
# ARANGO_URL=https://your-instance.arangodb.cloud:8529
